PORT=3001
NODE_ENV=development
API_VERSION=v1

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_key_here
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Origin
CLIENT_URL=http://localhost:3000

# Database Connection (Targeting SQL Server)
DATABASE_URL="sqlserver://HOST:1433;database=Phela;user=sa;password=PASSWORD;trustServerCertificate=true"
